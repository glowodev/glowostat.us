---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Toast from "../../components/Toast.astro";
import {
  classLabels,
  statusCodes,
  type StatusCode,
} from "../../data/status-codes";
import { describeCode } from "../../data/status-descriptions";
import {
  highlightSnippet,
  renderSnippet,
  snippetLabels,
  snippetLangs,
} from "../../lib/snippets";

export const getStaticPaths = () =>
  statusCodes.map((c) => ({
    params: { code: String(c.code) },
    props: { code: c },
  }));

type Props = { code: StatusCode };

const { code } = Astro.props;
const description = describeCode(code.code, code.name);
const url = `https://glowostat.us/${code.code}`;
const cls = code.class;
const colorVar = `var(--color-class-${cls})`;
const className = classLabels[cls];

const seoTitle = `HTTP ${code.code} ${code.name} — test it live | glowostat.us`;
const seoDescription = `${code.code} ${code.name}: ${description} Test it instantly with curl, fetch, Python, Go, or Node — open ${url} or copy the snippet.`;

// Pre-render every snippet so the page is fully static and fast.
const snippets = snippetLangs.map((lang) => ({
  lang,
  label: snippetLabels[lang],
  text: renderSnippet(lang, url),
  html: highlightSnippet(renderSnippet(lang, url), code.code, cls),
}));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://glowostat.us/" },
    { "@type": "ListItem", position: 2, name: "HTTP status codes", item: "https://glowostat.us/#table" },
    { "@type": "ListItem", position: 3, name: `${code.code} ${code.name}`, item: `https://glowostat.us/codes/${code.code}/` },
  ],
};

const techArticleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: `HTTP ${code.code} ${code.name}`,
  description,
  about: { "@type": "Thing", name: `HTTP status ${code.code}` },
  url: `https://glowostat.us/codes/${code.code}/`,
  isPartOf: { "@type": "WebSite", url: "https://glowostat.us" },
};

// Adjacent codes for prev/next navigation — keeps the internal link graph dense.
const idx = statusCodes.findIndex((c) => c.code === code.code);
const prev = idx > 0 ? statusCodes[idx - 1] : null;
const next = idx < statusCodes.length - 1 ? statusCodes[idx + 1] : null;
---

<Layout
  title={seoTitle}
  description={seoDescription}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbSchema)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(techArticleSchema)}
    />
  </Fragment>

  <Nav />

  <main id="main">
    <article class="mx-auto max-w-[920px] px-6 pb-24 pt-12">
      <nav
        class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[11px] uppercase tracking-[0.12em] text-muted"
        aria-label="Breadcrumb"
      >
        <a href="/" class="transition-colors hover:text-emerald">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/#table" class="transition-colors hover:text-emerald">Status codes</a>
        <span aria-hidden="true">/</span>
        <span class="text-foreground">{code.code}</span>
      </nav>

      <header class="mt-8">
        <p
          class="font-mono text-[11px] uppercase tracking-[0.14em]"
          style={`color: ${colorVar}`}
        >
          {cls} · {className}
        </p>
        <h1
          class="mt-3 break-words font-display text-4xl font-bold leading-[1.05] tracking-[-0.02em] text-foreground sm:text-6xl"
        >
          <span style={`color: ${colorVar}`}>{code.code}</span>{" "}
          {code.name}
        </h1>
        <p class="mt-5 max-w-2xl text-base text-muted sm:text-lg">
          {description}
        </p>
      </header>

      <section class="mt-10 rounded-xl bg-surface-raised/60 p-6">
        <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-emerald">
          Test it
        </h2>
        <div class="mt-3 rounded-lg bg-bg/60 px-4 py-3 font-mono text-[14px]">
          <span class="text-muted">https://glowostat.us/</span><span
            style={`color: ${colorVar}`}
            class="font-semibold">{code.code}</span>
        </div>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <a
            href={url}
            target="_blank"
            rel="noreferrer noopener"
            class="inline-flex items-center gap-2 rounded-lg bg-emerald px-4 py-2 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-bg transition-opacity hover:opacity-90"
          >
            Open {code.code} ↗
          </a>
          <button
            type="button"
            data-copy={`curl -i ${url}`}
            class="inline-flex items-center gap-2 rounded-lg border border-border-ghost px-4 py-2 font-mono text-[12px] uppercase tracking-[0.08em] text-muted transition-colors hover:border-emerald/40 hover:text-emerald"
          >
            Copy curl
          </button>
        </div>
      </section>

      <section class="mt-10">
        <h2 class="font-display text-2xl font-semibold tracking-[-0.02em] text-foreground">
          Snippets
        </h2>
        <p class="mt-2 text-[14px] text-muted">
          Same URL, every common HTTP client.
        </p>
        <div class="mt-5 flex flex-col gap-4">
          {
            snippets.map((s) => (
              <figure class="overflow-hidden rounded-xl bg-surface-raised">
                <figcaption class="flex items-center justify-between border-b border-border-ghost px-5 py-3">
                  <span class="font-mono text-[11px] lowercase text-foreground">
                    {s.label}
                  </span>
                  <button
                    type="button"
                    data-copy={s.text}
                    class="inline-flex items-center gap-1.5 rounded-md border border-border-ghost px-2.5 py-1.5 font-mono text-[10px] uppercase tracking-[0.12em] text-muted transition-colors hover:border-emerald/40 hover:text-emerald"
                    aria-label={`Copy ${s.label} snippet`}
                  >
                    Copy
                  </button>
                </figcaption>
                <pre class="overflow-x-auto bg-bg/40 p-5 font-mono text-[13px] leading-relaxed text-foreground"><code set:html={s.html} /></pre>
              </figure>
            ))
          }
        </div>
      </section>

      <nav
        class="mt-12 flex flex-col gap-3 border-t border-border-ghost pt-6 sm:flex-row sm:items-center sm:justify-between"
        aria-label="Adjacent status codes"
      >
        {
          prev ? (
            <a
              href={`/codes/${prev.code}`}
              class="inline-flex flex-col gap-0.5 text-left transition-colors hover:text-emerald"
            >
              <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-dim">
                ← Previous
              </span>
              <span class="font-mono text-[13px] text-muted">
                {prev.code} {prev.name}
              </span>
            </a>
          ) : (
            <span />
          )
        }
        <a
          href="/#table"
          class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted transition-colors hover:text-emerald"
        >
          All codes
        </a>
        {
          next ? (
            <a
              href={`/codes/${next.code}`}
              class="inline-flex flex-col gap-0.5 text-right transition-colors hover:text-emerald"
            >
              <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-dim">
                Next →
              </span>
              <span class="font-mono text-[13px] text-muted">
                {next.code} {next.name}
              </span>
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </article>
  </main>

  <Footer />
  <Toast />

  <script>
    import "../../scripts/landing.ts";
  </script>
</Layout>
