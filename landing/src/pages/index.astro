---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import PeriodicTable from "../components/PeriodicTable.astro";
import MiniPlayground from "../components/MiniPlayground.astro";
import PowerFeatures from "../components/PowerFeatures.astro";
import Snippets from "../components/Snippets.astro";
import TrustBlock from "../components/TrustBlock.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import Toast from "../components/Toast.astro";
---

<Layout>
  <Nav />
  <main id="main">
    <Hero />
    <PeriodicTable />
    <PowerFeatures />
    <Snippets />
    <TrustBlock />
    <Faq />
  </main>
  <Footer />
  <MiniPlayground />
  <Toast />

  <script>
    import "../scripts/landing.ts";
  </script>
</Layout>
