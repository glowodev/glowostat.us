---
import FeatureCard from "./FeatureCard.astro";
---

<section
  id="tools"
  class="mx-auto max-w-[1200px] px-6 pb-32 pt-16"
  aria-label="Request tools"
>
  <header class="mx-auto mb-12 max-w-2xl text-center">
    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-emerald">
      Request tools
    </p>
    <h2 class="mt-3 font-display text-3xl font-semibold leading-tight tracking-[-0.02em] text-foreground sm:text-4xl">
      Not just status codes.
    </h2>
    <p class="mt-3 text-base text-muted">
      httpbin-style endpoints for exercising the rest of your HTTP client:
      echo, redirects, auth, and slow servers.
    </p>
  </header>

  <div class="grid gap-6 sm:grid-cols-2">
    <FeatureCard
      label="Echo"
      description="See exactly what your client sent: query args, request headers, your origin IP, and the full URL — as JSON, never logged."
      copyValue="https://glowostat.us/get"
    >
      <span class="text-muted">GET /</span><span style="color: var(--color-class-2xx)">get</span>
      <br />
      <span class="text-muted">{"{"} args, headers, origin, url {"}"}</span>
    </FeatureCard>

    <FeatureCard
      label="Redirect chain"
      description="302-redirects n times (up to 10) before landing on /get. Validate follow-redirect logic, hop limits, and Location handling."
      copyValue="curl -iL https://glowostat.us/redirect/3"
    >
      <span class="text-muted">GET /</span><span style="color: var(--color-class-3xx)">redirect/3</span>
      <br />
      <span style="color: var(--color-class-3xx)">302</span><span class="text-muted"> → </span><span style="color: var(--color-class-3xx)">302</span><span class="text-muted"> → </span><span style="color: var(--color-class-3xx)">302</span><span class="text-muted"> → /get</span>
    </FeatureCard>

    <FeatureCard
      label="Basic auth"
      description="Challenges with 401 + WWW-Authenticate until the credentials in the path match. UTF-8 aware, case-insensitive scheme."
      copyValue="curl -iu user:pass https://glowostat.us/basic-auth/user/pass"
    >
      <span class="text-muted">GET /</span><span style="color: var(--color-class-4xx)">basic-auth</span><span class="text-muted">/</span><span style="color: var(--color-class-2xx)">user</span><span class="text-muted">/</span><span style="color: var(--color-class-2xx)">pass</span>
      <br />
      <span style="color: var(--color-class-4xx)">401</span><span class="text-muted"> challenge → </span><span style="color: var(--color-class-2xx)">200</span><span class="text-muted"> with creds</span>
    </FeatureCard>

    <FeatureCard
      label="Slow server"
      description="Holds the JSON echo for n seconds (up to 10) — a slow upstream in one URL. Combine with ?sleep= for millisecond control."
      copyValue="https://glowostat.us/delay/3"
    >
      <span class="text-muted">GET /</span><span style="color: var(--color-class-5xx)">delay/3</span>
      <br />
      <span class="text-muted">responds after 3&thinsp;s</span>
    </FeatureCard>
  </div>
</section>
