---
import {
  snippetLangs,
  snippetLabels,
  renderSnippet,
  highlightSnippet,
  type SnippetLang,
} from "../lib/snippets";

const defaultUrl = "https://glowostat.us/500";
const defaultCode = 500;
const defaultClass = "5xx" as const;
const defaultLang: SnippetLang = "curl";
const defaultSnippet = renderSnippet(defaultLang, defaultUrl);
const defaultHtml = highlightSnippet(defaultSnippet, defaultCode, defaultClass);

// Pre-render every snippet so client switching is purely text swap.
const allSnippets: Record<SnippetLang, string> = Object.fromEntries(
  snippetLangs.map((l) => [l, renderSnippet(l, defaultUrl)]),
) as Record<SnippetLang, string>;
---

<section
  id="snippets"
  class="mx-auto max-w-[1200px] px-6 pb-32 pt-16"
  aria-label="Drop-in snippets"
>
  <header class="mx-auto mb-12 max-w-2xl text-center">
    <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-class-1xx">
      Drop-in snippets
    </p>
    <h2 class="mt-3 font-display text-3xl font-semibold leading-tight tracking-[-0.02em] text-foreground sm:text-4xl">
      Copy. Paste. Ship.
    </h2>
    <p class="mt-3 text-base text-muted">
      Same URL, every common HTTP client.
    </p>
  </header>

  <div
    id="snippet-block"
    data-url="https://glowostat.us/500"
    data-lang={defaultLang}
    class="mx-auto max-w-[960px] overflow-hidden rounded-xl bg-surface-raised"
  >
    <div class="flex items-center justify-between gap-4 border-b border-border-ghost px-5 py-3">
      <div class="flex items-center gap-1 overflow-x-auto">
        {
          snippetLangs.map((lang) => (
            <button
              type="button"
              data-lang-tab={lang}
              class:list={[
                "snippet-tab relative px-3 py-2 font-mono text-[12px] lowercase transition-colors",
                lang === defaultLang ? "text-foreground" : "text-muted hover:text-foreground",
              ]}
              aria-pressed={lang === defaultLang ? "true" : "false"}
            >
              {snippetLabels[lang]}
              {lang === defaultLang && (
                <span data-tab-indicator="true" class="absolute inset-x-2 -bottom-px h-0.5 bg-emerald" aria-hidden="true" />
              )}
            </button>
          ))
        }
      </div>

      <button
        type="button"
        id="snippet-copy"
        data-copy={defaultSnippet}
        class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-border-ghost px-2.5 py-1.5 font-mono text-[10px] uppercase tracking-[0.12em] text-muted transition-colors hover:border-emerald/40 hover:text-emerald"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="size-3"
          aria-hidden="true"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        Copy
      </button>
    </div>

    <pre
      id="snippet-pre"
      class="min-h-[300px] overflow-x-auto bg-bg/40 p-6 font-mono text-[13.5px] leading-relaxed text-foreground"
    ><code id="snippet-code" set:html={defaultHtml} /></pre>
  </div>

  <script
    is:inline
    type="application/json"
    data-snippets
    set:html={JSON.stringify(allSnippets)}
  />
</section>
