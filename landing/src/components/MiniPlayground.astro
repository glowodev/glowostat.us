---
// Default selection on load: 200 OK
---

<aside
  id="mini-playground"
  class="hidden sm:block fixed bottom-6 right-6 z-30 w-[360px] rounded-2xl border border-border-ghost bg-surface-raised/85 p-4 shadow-[0_24px_60px_rgba(0,0,0,0.45)] backdrop-blur-xl"
  data-selected="200"
  role="region"
  aria-label="Selected status code"
>
  <div class="flex items-center justify-between">
    <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-emerald">
      Playground
    </span>
    <span class="flex items-center gap-2 font-mono text-[11px]">
      <span
        id="mp-dot"
        class="block size-2 rounded-full"
        style="background: var(--color-class-2xx)"
        aria-hidden="true"
      ></span>
      <span id="mp-label" class="text-muted">
        <span id="mp-code" class="text-foreground">200</span> OK
      </span>
    </span>
  </div>

  <div class="mt-3 rounded-lg bg-bg/60 px-3 py-2 font-mono text-[13px] leading-tight">
    <span class="text-muted">https://glowostat.us/</span><span
      id="mp-url-code"
      style="color: var(--color-class-2xx)"
      class="font-semibold">200</span>
  </div>

  <div class="mt-3 flex items-center gap-2">
    <button
      type="button"
      id="mp-copy"
      data-copy="curl -i https://glowostat.us/200"
      class="flex flex-1 items-center justify-center gap-2 rounded-lg bg-emerald px-3 py-2 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-bg transition-opacity hover:opacity-90"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        class="size-3.5"
        aria-hidden="true"
      >
        <rect x="9" y="9" width="13" height="13" rx="2" />
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
      </svg>
      <span data-mp-copy-label>Copy curl</span>
    </button>
    <a
      id="mp-open"
      href="https://glowostat.us/200"
      target="_blank"
      rel="noreferrer noopener"
      class="flex items-center justify-center rounded-lg border border-border-ghost px-3 py-2 font-mono text-[11px] uppercase tracking-[0.08em] text-muted transition-colors hover:border-emerald/40 hover:text-emerald"
      aria-label="Open in new tab"
    >
      ↗
    </a>
  </div>

  <p class="mt-2 text-center font-mono text-[10px] text-dim">
    Click any tile to update.
  </p>
</aside>
