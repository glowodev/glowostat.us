---
import Wordmark from "./Wordmark.astro";

const repoUrl = "https://github.com/glowodev/glowostat.us";

const links = [
  { href: "#table", label: "Reference" },
  { href: "#snippets", label: "Snippets" },
  { href: "#features", label: "Features" },
  { href: "#tools", label: "Tools" },
  { href: repoUrl, label: "Source" },
];
---

<nav class="relative z-20 mx-auto flex max-w-[1280px] items-center justify-between px-6 py-5">
  <a href="/" class="block" aria-label="glowostat.us home">
    <Wordmark size="md" />
  </a>

  <div class="flex items-center gap-1">
    <div class="hidden items-center gap-1 sm:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="px-3 py-2 font-mono text-[11px] uppercase tracking-[0.12em] text-muted transition-colors hover:text-emerald"
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <a
      href={repoUrl}
      target="_blank"
      rel="noreferrer noopener"
      class="group ml-2 inline-flex items-stretch overflow-hidden rounded-lg border border-border-ghost bg-surface-raised transition-colors hover:border-emerald/60"
      aria-label="Star glowostat.us on GitHub"
    >
      <span
        class="flex items-center gap-2 px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.12em] text-foreground transition-colors group-hover:text-emerald"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-4"
          aria-hidden="true"
        >
          <path
            d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 008.86 11.2c.65.12.89-.28.89-.62 0-.31-.01-1.13-.02-2.22-3.6.78-4.36-1.56-4.36-1.56-.59-1.5-1.45-1.9-1.45-1.9-1.18-.81.09-.79.09-.79 1.31.09 2 1.35 2 1.35 1.16 1.99 3.05 1.41 3.79 1.08.12-.84.45-1.41.82-1.74-2.87-.33-5.89-1.43-5.89-6.38 0-1.41.5-2.56 1.34-3.46-.13-.33-.58-1.65.13-3.45 0 0 1.09-.35 3.58 1.32a12.4 12.4 0 016.51 0c2.49-1.67 3.58-1.32 3.58-1.32.71 1.8.26 3.12.13 3.45.83.9 1.34 2.05 1.34 3.46 0 4.96-3.03 6.05-5.91 6.37.46.4.88 1.18.88 2.37 0 1.71-.02 3.09-.02 3.51 0 .34.24.74.9.62A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"
          />
        </svg>
        <span>Star</span>
      </span>
      <span
        class="flex items-center gap-1 border-l border-border-ghost bg-surface-raised/60 px-3 py-1.5 font-mono text-[11px] text-emerald transition-colors group-hover:bg-surface-raised group-hover:text-emerald"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="size-3"
          aria-hidden="true"
        >
          <path d="M12 .587l3.668 7.568L24 9.423l-6 5.84 1.42 8.27L12 19.45 4.58 23.533 6 15.263l-6-5.84 8.332-1.268z" />
        </svg>
      </span>
    </a>
  </div>
</nav>
