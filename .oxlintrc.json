{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn",
    "style": "off"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "landing/dist",
    ".astro",
    ".wrangler",
    "**/*.astro"
  ],
  "overrides": [
    {
      "files": ["test/**/*.ts"],
      "rules": {
        "no-await-in-loop": "off"
      }
    }
  ]
}
